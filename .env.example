# ─── Base de datos (Supabase) ────────────────────────────────────────────────
# Conexión pooling (puerto 6543) — para el cliente en runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexión directa (puerto 5432) — solo para migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generá con: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública de la app (sin trailing slash)
NEXT_PUBLIC_APP_URL="https://tuscortes.com"

# ─── Supabase Storage (uploads de imágenes) ──────────────────────────────────
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Opcional — por defecto usa "TusCortes <noreply@tuscortes.com>"
# RESEND_FROM="TusCortes <noreply@tuscortes.com>"

# ─── WhatsApp (Twilio) — opcional ────────────────────────────────────────────
# Si no se configuran, las notificaciones por WhatsApp se omiten silenciosamente
# Conseguís estas credenciales en: console.twilio.com
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"   ← sandbox / reemplazá por tu número aprobado

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Secret para autenticar el endpoint /api/cron/reminders en producción
# Generá con: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# ─── Cancelaciones ───────────────────────────────────────────────────────────
# Secret para firmar tokens de cancelación. Si no se setea, usa AUTH_SECRET.
# CANCEL_SECRET="your-cancel-secret-here"

# ─── MercadoPago ─────────────────────────────────────────────────────────────
# Links de pago para cada plan (obtenelos desde tu cuenta de MercadoPago)
NEXT_PUBLIC_MP_LINK_STARTER="https://mpago.la/xxxxxxx"
NEXT_PUBLIC_MP_LINK_PRO="https://mpago.la/xxxxxxx"
NEXT_PUBLIC_MP_LINK_PREMIUM="https://mpago.la/xxxxxxx"

# ─── Seed (solo para desarrollo/staging) ─────────────────────────────────────
# Requerido para correr: npx prisma db seed
SEED_SUPERADMIN_EMAIL="admin@tuscortes.com"
SEED_SUPERADMIN_PASSWORD="cambia-esta-password"
SEED_DEMO_EMAIL="owner@ramoscutz.com"
SEED_DEMO_PASSWORD="cambia-esta-password"
